        protected static ObjectId PromptForEntity(string message, Type entityType)
        {
            try
            {
                PromptEntityOptions opts = new PromptEntityOptions(message);
                opts.SetRejectMessage($"\nSelected entity is not a {entityType.Name}");
                opts.AddAllowedClass(entityType, false);

                PromptEntityResult result = Ed.GetEntity(opts);
                return result.Status == PromptStatus.OK ? result.ObjectId : ObjectId.Null;
            }
            catch (System.Exception ex)
            {
                Ed.WriteMessage($"\nError in entity selection: {ex.Message}");
            }
            return ObjectId.Null;
        }

        public static async Task<ThreeLeggedToken> Get3LeggedTokenAsync()
        {
            //Instantiate SDK manager 
            SDKManager sdkManager = SdkManagerBuilder.Create()
                .Build();

            //Instantiate Authentication client using the SDK manager
            AuthenticationClient authenticationClient = new AuthenticationClient(sdkManager);

            //string clientId = Environment.GetEnvironmentVariable("ACC_CLIENT_ID");
            //string clientSecret = Environment.GetEnvironmentVariable("ACC_CLIENT_SECRET");
            string clientId = "wy2O1KSEXdVLRU70cRq9y7DlPPGdWmXhPlRZFJHYpU0DhoK3";
            if (string.IsNullOrWhiteSpace(clientId))
            {
                Ed.WriteMessage("\nUNABLE TO OBTAIN CLIENT ID");
                return null;
            }

            var pkce = new Pkce
            {
                _CodeVerifier = GenerateCodeVerifier(32)
            };
            using (var sha256 = SHA256.Create())
            {
                // Here we create a hash of the code verifier
                var challengeBytes = sha256.ComputeHash(Encoding.UTF8.GetBytes(pkce._CodeVerifier));

                // and produce the "Code Challenge" from it by base64Url encoding it.
                pkce._CodeChallenge = Base64UrlEncode(challengeBytes);
            }


            // store pkce so the code_verifier can be used later when exchanging the auth code
            _lastPkce = pkce;

            // Build authorization URL for loopback PKCE flow
            string redirect = _redirUrl; // should be http://localhost:8080/callback/
            string scopes = "data:read data:write"; // adjust scopes as needed for your app
            string authUrl = $"https://developer.api.autodesk.com/authentication/v1/authorize?response_type=code&client_id={Uri.EscapeDataString(clientId)}&redirect_uri={Uri.EscapeDataString(redirect)}&scope={Uri.EscapeDataString(scopes)}&code_challenge={pkce._CodeChallenge}&code_challenge_method=S256";

            try
            {
                Ed.WriteMessage("\nStarting interactive 3-legged auth (browser should open)...");

                using (var listener = new HttpListener())
                {
                    listener.Prefixes.Add(redirect);
                    try
                    {
                        listener.Start();
                    }
                    catch (Exception exStart)
                    {
                        Ed.WriteMessage($"\nFailed to start HttpListener: {exStart.Message}");
                        return null;
                    }

                    try
                    {
                        // Open the user's browser to the authorization URL
                        try
                        {
                            Process.Start(new ProcessStartInfo { FileName = authUrl, UseShellExecute = true });
                        }
                        catch (Exception exOpen)
                        {
                            Ed.WriteMessage($"\nFailed to open browser: {exOpen.Message}");
                        }

                        // Wait for the incoming authorization response (with a timeout)
                        var contextTask = listener.GetContextAsync();
                        var completed = await Task.WhenAny(contextTask, Task.Delay(TimeSpan.FromMinutes(2))).ConfigureAwait(false);
                        if (completed != contextTask)
                        {
                            Ed.WriteMessage("\nTimed out waiting for authorization response.");
                            try { listener.Stop(); } catch { }
                            return null;
                        }

                        var context = await contextTask.ConfigureAwait(false);
                        var qs = context.Request.QueryString;
                        var code = qs["code"];
                        var error = qs["error"];

                        // Respond to the browser so the user sees a confirmation page
                        var respString = "<html><body>Authentication complete. You can close this window.</body></html>";
                        var buffer = Encoding.UTF8.GetBytes(respString);
                        context.Response.ContentLength64 = buffer.Length;
                        context.Response.OutputStream.Write(buffer, 0, buffer.Length);
                        context.Response.OutputStream.Close();
                        try { listener.Stop(); } catch { }

                        if (!string.IsNullOrWhiteSpace(error))
                        {
                            Ed.WriteMessage($"\nAuthorization error: {error}");
                            return null;
                        }
                        if (string.IsNullOrWhiteSpace(code))
                        {
                            Ed.WriteMessage("\nNo authorization code received.");
                            return null;
                        }

                        // Exchange authorization code for tokens using the token endpoint
                        using var http = new HttpClient();
                        var form = new Dictionary<string, string>
                        {
                            { "client_id", clientId },
                            { "grant_type", "authorization_code" },
                            { "code", code },
                            { "redirect_uri", redirect },
                            { "code_verifier", pkce._CodeVerifier }
                        };

                        var tokenResp = await http.PostAsync("https://developer.api.autodesk.com/authentication/v1/gettoken", new FormUrlEncodedContent(form)).ConfigureAwait(false);
                        var tokenJson = await tokenResp.Content.ReadAsStringAsync().ConfigureAwait(false);
                        if (!tokenResp.IsSuccessStatusCode)
                        {
                            Ed.WriteMessage($"\nToken request failed: {tokenResp.StatusCode} {tokenJson}");
                            return null;
                        }

                        var tokenObj = JsonSerializer.Deserialize<ThreeLeggedToken>(tokenJson);
                        Ed.WriteMessage("\nGetThreeLeggedTokenAsync returned a token.");
                        return tokenObj;
                    }
                    catch (Exception exInner)
                    {
                        Ed.WriteMessage($"\nError during auth flow: {exInner.Message}");
                        try { listener.Stop(); } catch { }
                        return null;
                    }
                }
            }
            catch (Exception ex)
            {
                Ed.WriteMessage($"\nGetThreeLeggedTokenAsync failed: {ex.Message}");
                return null;
            }
        }

        // Reusable helper: fetch an ACC attribute value for a given project/item via the Datamanagement SDK (async)
        protected static async Task<string> GetAccAttributeValue(string token, string attributeName, string endpointUrl, string projectId, string fileId)
        {
            try
            {
                string projId = projectId ?? Environment.GetEnvironmentVariable("ACC_PROJECT_ID");
                string fid = fileId ?? Environment.GetEnvironmentVariable("ACC_FILE_ID");

                if (string.IsNullOrWhiteSpace(projId) || string.IsNullOrWhiteSpace(fid))
                {
                    var derived = await GetAccProjectAndFileFromDrawing(token).ConfigureAwait(false);
                    if (derived != null)
                    {
                        projId ??= derived.Item1;
                        fid ??= derived.Item2;
                    }
                }

                if (string.IsNullOrWhiteSpace(projId) || string.IsNullOrWhiteSpace(fid))
                {
                    Ed.WriteMessage("\nNo endpoint or project/file identifiers provided to fetch ACC attribute.");
                    return null;
                }

#if DATAMANAGEMENT
                // Use DatamanagementClient from the Adsk.Platform.Datamanagement package
                var client = new DatamanagementClient();

                try
                {
                    var metadata = await client.GetItemMetadataAsync(projId, fid, token).ConfigureAwait(false);
                    if (metadata != null)
                    {
                        var attrs = metadata.Attributes ?? metadata.Metadata ?? metadata.Data;
                        if (attrs != null)
                        {
                            if (attrs is IDictionary<string, object> dict)
                            {
                                if (dict.TryGetValue(attributeName, out var v)) return v?.ToString();
                            }
                            else
                            {
                                var prop = attrs.GetType().GetProperty(attributeName);
                                if (prop != null) return prop.GetValue(attrs)?.ToString();
                                var valProp = attrs.GetType().GetProperty("value", System.Reflection.BindingFlags.IgnoreCase | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);
                                if (valProp != null) return valProp.GetValue(attrs)?.ToString();
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    Ed.WriteMessage($"\nDatamanagement SDK metadata call failed: {ex.Message}");
                }
#else
                Ed.WriteMessage("\nDatamanagement SDK not available at compile time. Define DATAMANAGEMENT to enable.");
#endif
            }
            catch (System.Exception ex)
            {
                Ed.WriteMessage($"\nError fetching ACC attribute value: {ex.Message}");
            }
            return null;
        }

        // Attempt to derive ACC project id and file id from the current drawing by matching folder name -> project and filename -> item
        protected static async Task<Tuple<string, string>> GetAccProjectAndFileFromDrawing(string token)
        {
#if DATAMANAGEMENT
            try
            {
                string dwgPath = AcadDoc?.Database?.Filename;
                if (string.IsNullOrWhiteSpace(dwgPath))
                {
                    Ed.WriteMessage("\nCannot determine DWG filename/path.");
                    return null;
                }

                string fileName = System.IO.Path.GetFileName(dwgPath);
                string folder = System.IO.Path.GetDirectoryName(dwgPath);
                string lastFolder = string.IsNullOrWhiteSpace(folder) ? null : new System.IO.DirectoryInfo(folder).Name;

                if (string.IsNullOrWhiteSpace(lastFolder) || string.IsNullOrWhiteSpace(fileName))
                {
                    Ed.WriteMessage("\nCannot derive project or file name from DWG path.");
                    return null;
                }

                var client = new DatamanagementClient();

                // List projects and find one matching lastFolder
                var projects = await client.ListProjectsAsync(token).ConfigureAwait(false);
                if (projects == null)
                {
                    Ed.WriteMessage("\nNo projects returned from Datamanagement SDK.");
                    return null;
                }

                string foundProjectId = null;
                foreach (var proj in projects)
                {
                    if (!string.IsNullOrWhiteSpace(proj.Name) && string.Equals(proj.Name, lastFolder, StringComparison.OrdinalIgnoreCase))
                    {
                        foundProjectId = proj.Id; break;
                    }
                    if (!string.IsNullOrWhiteSpace(proj.DisplayName) && string.Equals(proj.DisplayName, lastFolder, StringComparison.OrdinalIgnoreCase))
                    {
                        foundProjectId = proj.Id; break;
                    }
                }

                if (string.IsNullOrWhiteSpace(foundProjectId))
                {
                    Ed.WriteMessage($"\nNo project matching '{lastFolder}' found in ACC.");
                    return null;
                }

                // List items in the project and find one matching fileName
                var items = await client.ListItemsAsync(foundProjectId, token).ConfigureAwait(false);
                if (items == null)
                {
                    Ed.WriteMessage("\nNo items returned for project.");
                    return null;
                }

                string foundItemId = null;
                foreach (var item in items)
                {
                    if (!string.IsNullOrWhiteSpace(item.Name) && string.Equals(item.Name, fileName, StringComparison.OrdinalIgnoreCase))
                    {
                        foundItemId = item.Id; break;
                    }
                    if (!string.IsNullOrWhiteSpace(item.DisplayName) && string.Equals(item.DisplayName, fileName, StringComparison.OrdinalIgnoreCase))
                    {
                        foundItemId = item.Id; break;
                    }
                }

                if (string.IsNullOrWhiteSpace(foundItemId))
                {
                    Ed.WriteMessage($"\nNo item matching '{fileName}' found in project.");
                    return null;
                }

                return Tuple.Create(foundProjectId, foundItemId);
            }
            catch (Exception ex)
            {
                Ed.WriteMessage($"\nError deriving ACC project/file from drawing: {ex.Message}");
            }
            return null;
#else
            Ed.WriteMessage("\nDatamanagement SDK not available at compile time. Define DATAMANAGEMENT to enable.");
            await Task.CompletedTask;
            return null;
#endif
        }

        public static void Dump(string path)
        {
            var lines = AppDomain.CurrentDomain
                .GetAssemblies()
                .OrderBy(a => a.GetName().Name)
                .Select(a =>
                {
                    string loc;
                    try { loc = a.Location; } catch { loc = "<no location>"; }
                    return $"{a.GetName().Name} | {a.GetName().Version} | {loc}";
                });

            File.WriteAllLines(path, lines);
        }

        // Hook: improved resolver that falls back to stream loading when LoadFromAssemblyPath fails.
        // It also logs assembly identity diagnostics to the specified log file.
        public static void Hook(string path)
        {
            var pluginDir = Path.GetDirectoryName(typeof(Functions).Assembly.Location) ?? AppContext.BaseDirectory;

            AssemblyLoadContext.Default.Resolving += (context, name) =>
            {
                try
                {
                    File.AppendAllText(path, $"Resolving: {name}\n");

                    if (name == null || string.IsNullOrEmpty(name.Name)) return null;

                    string candidate = Path.Combine(pluginDir, name.Name + ".dll");
                    if (!File.Exists(candidate))
                    {
                        File.AppendAllText(path, $"Candidate not found in plugin folder: {candidate}\n");
                        return null;
                    }

                    File.AppendAllText(path, $"Found candidate: {candidate}\n");

                    // Log the candidate assembly's identity (helpful for diagnosing version/PKT mismatches)
                    try
                    {
                        var asmName = System.Reflection.AssemblyName.GetAssemblyName(candidate);
                        var pkt = asmName.GetPublicKeyToken();
                        string pktStr = pkt == null || pkt.Length == 0 ? "<none>" : BitConverter.ToString(pkt).Replace("-", "");
                        File.AppendAllText(path, $"Candidate identity: {asmName.Name} | {asmName.Version} | PKT={pktStr}\n");
                    }
                    catch (Exception ex)
                    {
                        File.AppendAllText(path, $"GetAssemblyName failed: {ex.Message}\n");
                    }

                    // Primary attempt: load from path (best for dependency resolution)
                    try
                    {
                        var loaded = AssemblyLoadContext.Default.LoadFromAssemblyPath(candidate);
                        File.AppendAllText(path, $"Loaded from path: {loaded.FullName}\n");
                        return loaded;
                    }
                    catch (System.IO.FileLoadException fle)
                    {
                        // Common when the file is blocked, or loader refuses; try stream approach
                        File.AppendAllText(path, $"LoadFromAssemblyPath failed: {fle.Message}\nAttempting LoadFromStream fallback...\n");
                        try
                        {
                            using var fs = File.OpenRead(candidate);
                            var asm = AssemblyLoadContext.Default.LoadFromStream(fs);
                            File.AppendAllText(path, $"Loaded via stream: {asm.FullName}\n");
                            return asm;
                        }
                        catch (Exception exStream)
                        {
                            File.AppendAllText(path, $"LoadFromStream failed: {exStream}\n");
                            return null;
                        }
                    }
                    catch (Exception exLoad)
                    {
                        File.AppendAllText(path, $"LoadFromAssemblyPath failed (other): {exLoad}\n");
                        return null;
                    }
                }
                catch (Exception exOuter)
                {
                    try { File.AppendAllText(path, $"Resolver outer exception: {exOuter}\n"); } catch { }
                    return null;
                }
            };
        }
