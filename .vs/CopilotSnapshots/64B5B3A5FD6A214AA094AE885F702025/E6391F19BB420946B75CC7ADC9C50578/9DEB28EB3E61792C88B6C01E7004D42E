using Autodesk.Authentication;
using Autodesk.SDKManager;
using Autodesk.Authentication.Model;
using System.Threading.Tasks;
using System;

namespace AccC3DMetadata
{
    // Small wrapper around the Autodesk AuthenticationClient so auth logic lives in its own file/class
    public class AuthService
    {
        private readonly SDKManager _sdkManager;
        private readonly AuthenticationClient _authClient;

        public AuthService()
        {
            _sdkManager = SdkManagerBuilder.Create().Build();
            _authClient = new AuthenticationClient(_sdkManager);
        }

        // This mirrors the SDK method used previously and simply delegates to AuthenticationClient
        public Task<ThreeLeggedToken> GetThreeLeggedTokenAsync(string clientId, string codeChallenge, string redirectUri)
        {
            return _authClient.GetThreeLeggedTokenAsync(clientId, codeChallenge, redirectUri);
        }
    }
}
