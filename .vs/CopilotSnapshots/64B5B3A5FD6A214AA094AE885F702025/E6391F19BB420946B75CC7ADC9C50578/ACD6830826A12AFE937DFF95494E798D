namespace AccC3DMetadata
{
    public class Commands : Functions
    {

        [CommandMethod("C3DCMD", "SyncAccAttributeToBlock", CommandFlags.Modal)]
        public async void SyncAccAttributeToBlock()
        {
            try
            {
                // For testing: use an in-memory list of mappings instead of reading from a JSON file
                var mappings = new List<AccBlockMapping>
                {
                    new AccBlockMapping
                    {
                        AccAttributeName = "AttributeA",
                        AccEndpointUrl = "https://example.com/acc/api/attrA",
                        AccProjectId = "projectA",
                        AccFileId = "fileA",
                        BlockName = "TestBlock",
                        BlockAttributeTag = "TAG_A"
                    },
                    new AccBlockMapping
                    {
                        AccAttributeName = "AttributeB",
                        AccEndpointUrl = "https://example.com/acc/api/attrB",
                        AccProjectId = "projectB",
                        AccFileId = "fileB",
                        BlockName = "TestBlock",
                        BlockAttributeTag = "TAG_B"
                    }
                };

                //Hook(@"C:\test\acad-assembly-log.txt");
                //Dump(@"C:\test\acad-loaded-assemblies.txt");

                // Acquire token via Authentication SDK
                ThreeLeggedToken token = await Functions.Get3LeggedTokenAsync();
                MessageBox.Show(token.ToString());

                using (Transaction tr = StartTransaction())
                {
                    Database db = AcadDoc.Database;
                    var currentSpace = tr.GetObject(db.CurrentSpaceId, OpenMode.ForRead) as BlockTableRecord;

                    foreach (var map in mappings)
                    {

                        //string accValue = await GetAccAttributeValue(token, map.AccAttributeName, map.AccEndpointUrl, map.AccProjectId, map.AccFileId).ConfigureAwait(false) ?? string.Empty;
                        string accValue = "TO BE IMPLEMENTED";
                        Ed.WriteMessage($"\nMapping '{map.AccAttributeName}' -> '{map.BlockName}.{map.BlockAttributeTag}': value='{accValue}'");

                        if (currentSpace == null) continue;

                        foreach (ObjectId entId in currentSpace)
                        {
                            var entObj = tr.GetObject(entId, OpenMode.ForRead);
                            var ent = entObj as Autodesk.AutoCAD.DatabaseServices.Entity;
                            if (ent is Autodesk.AutoCAD.DatabaseServices.BlockReference br && string.Equals(br.Name, map.BlockName, StringComparison.OrdinalIgnoreCase))
                            {
                                var brWrite = tr.GetObject(entId, OpenMode.ForWrite) as Autodesk.AutoCAD.DatabaseServices.BlockReference;
                                if (brWrite == null) continue;

                                foreach (ObjectId arId in brWrite.AttributeCollection)
                                {
                                    try
                                    {
                                        var ar = tr.GetObject(arId, OpenMode.ForWrite) as Autodesk.AutoCAD.DatabaseServices.AttributeReference;
                                        if (ar != null && string.Equals(ar.Tag, map.BlockAttributeTag, StringComparison.OrdinalIgnoreCase))
                                        {
                                            ar.TextString = accValue ?? string.Empty;
                                        }
                                    }
                                    catch (System.Exception ex)
                                    {
                                        Ed.WriteMessage($"\nError updating attribute: {ex.Message}");
                                    }
                                }
                            }
                        }
                    }

                    tr.Commit();
                    Ed.WriteMessage("\nACC attribute sync complete.");
                }
            }
            catch (System.Exception ex)
            {
                Ed.WriteMessage($"\nError in SyncAccAttributeToBlock: {ex.Message}");
            }
        }

    }
}
