using Autodesk.DataManagement;
using Autodesk.DataManagement.Model;
using Autodesk.SDKManager;
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Net.Http;
using System.Net.Http.Headers;
using System.Text;
using System.Text.Json;
using System.Threading.Tasks;

namespace AccC3DMetadata.Services
{
    internal class AccFileService
    {
        // ACC Files API — custom file attributes (no official NuGet; raw HTTP required)
        // Docs: https://aps.autodesk.com/en/docs/acc/v1/reference/http/files-items-:itemId-GET/
        private const string AccFilesBase = "https://developer.api.autodesk.com/construction/files/v1";

        private readonly DataManagementClient _dm;
        private readonly HttpClient _http = new();

        // Session-scoped cache: local DWG path → (hubId, projectId, itemId)
        private static readonly Dictionary<string, (string hub, string project, string item)> _itemCache = new();

        public AccFileService()
        {
            var sdk = SdkManagerBuilder.Create().Build();
            _dm = new DataManagementClient(sdk);
        }

        // ── Item discovery ─────────────────────────────────────────────────────────

        /// <summary>
        /// Resolves hub ID and project ID from a DWG opened via Desktop Connector, without
        /// performing a full folder search. Faster than ResolveItemFromDrawingPathAsync when
        /// the item ID is already known.
        /// </summary>
        public async Task<(string hubId, string projectId)> ResolveHubAndProjectAsync(
            string localPath, string accessToken)
        {
            var (hubName, projectName, _) = ParseDesktopConnectorPath(localPath);
            if (hubName == null)
                throw new InvalidOperationException(
                    $"Drawing path does not appear to be inside an Autodesk Desktop Connector folder.\nPath: {localPath}");

            var hubs = await _dm.GetHubsAsync(accessToken: accessToken).ConfigureAwait(false);
            var hub = FindByName(hubs?.Data, h => h.Attributes?.Name, hubName);
            if (hub == null)
            {
                var available = string.Join(", ", hubs?.Data?.Select(h => h.Attributes?.Name) ?? Enumerable.Empty<string>());
                throw new InvalidOperationException(
                    $"ACC hub '{hubName}' not found. Available hubs: [{available}]");
            }

            var projects = await _dm.GetHubProjectsAsync(hub.Id, accessToken: accessToken)
                .ConfigureAwait(false);
            var project = FindByName(projects?.Data, p => p.Attributes?.Name, projectName);
            if (project == null)
            {
                var available = string.Join(", ", projects?.Data?.Select(p => p.Attributes?.Name) ?? Enumerable.Empty<string>());
                throw new InvalidOperationException(
                    $"ACC project '{projectName}' not found in hub '{hub.Attributes?.Name}'. Available projects: [{available}]");
            }

            return (hub.Id, project.Id);
        }

        /// <summary>
        /// Derives the ACC hub ID, project ID, and item ID from a DWG opened via Desktop Connector.
        /// Desktop Connector sync path pattern:
        ///   %USERPROFILE%\Autodesk Forma\{hub-name}\{project-name}\{...}\{file}.dwg
        ///   %USERPROFILE%\DC\{hub-name}\{project-name}\{...}\{file}.dwg  (older DC)
        /// </summary>
        public async Task<(string hubId, string projectId, string itemId)> ResolveItemFromDrawingPathAsync(
            string localPath, string accessToken)
        {
            if (_itemCache.TryGetValue(localPath, out var cached))
                return cached;

            var (hubName, projectName, fileName) = ParseDesktopConnectorPath(localPath);
            if (hubName == null)
                throw new InvalidOperationException(
                    $"Drawing path does not appear to be inside an Autodesk Desktop Connector folder.\n" +
                    $"Path: {localPath}\n" +
                    "Add an explicit <DrawingItem itemId=\"...\"> to your .accsync.xml config to override.");

            // Find hub by display name
            var hubs = await _dm.GetHubsAsync(accessToken: accessToken).ConfigureAwait(false);
            var hub = FindByName(hubs?.Data, h => h.Attributes?.Name, hubName);
            if (hub == null)
            {
                var available = string.Join(", ", hubs?.Data?.Select(h => h.Attributes?.Name) ?? Enumerable.Empty<string>());
                throw new InvalidOperationException(
                    $"ACC hub '{hubName}' not found. Available hubs: [{available}]");
            }

            string hubId = hub.Id;

            // Find project by display name
            var projects = await _dm.GetHubProjectsAsync(hubId, accessToken: accessToken)
                .ConfigureAwait(false);
            var project = FindByName(projects?.Data, p => p.Attributes?.Name, projectName);
            if (project == null)
            {
                var available = string.Join(", ", projects?.Data?.Select(p => p.Attributes?.Name) ?? Enumerable.Empty<string>());
                throw new InvalidOperationException(
                    $"ACC project '{projectName}' not found in hub '{hub.Attributes?.Name}'. Available projects: [{available}]");
            }

            string projectId = project.Id;

            // Search all top folders for the file by display name
            var topFolders = await _dm.GetProjectTopFoldersAsync(
                hubId, projectId, accessToken: accessToken).ConfigureAwait(false);

            string itemId = null;
            foreach (TopFolderData folder in topFolders?.Data ?? Enumerable.Empty<TopFolderData>())
            {
                itemId = await SearchFolderForFileAsync(projectId, folder.Id, fileName, accessToken)
                    .ConfigureAwait(false);
                if (itemId != null) break;
            }

            if (itemId == null)
                throw new InvalidOperationException(
                    $"Could not find '{fileName}' in ACC project '{projectName}'. " +
                    "Add an explicit <DrawingItem itemId=\"...\"> to your .accsync.xml config.");

            var result = (hubId, projectId, itemId);
            _itemCache[localPath] = result;
            return result;
        }

        private async Task<string> SearchFolderForFileAsync(
            string projectId, string folderId, string fileName, string accessToken)
        {
            // No name-filter parameter exists in the SDK; retrieve and filter client-side.
            // Use dynamic to handle the polymorphic FolderContents.Data (items and folders).
            var contents = await _dm.GetFolderContentsAsync(
                projectId, folderId,
                accessToken: accessToken).ConfigureAwait(false);

            if (contents?.Data == null) return null;

            foreach (dynamic entry in contents.Data)
            {
                try
                {
                    string displayName = (string)entry.Attributes?.DisplayName;
                    if (string.Equals(displayName, fileName, StringComparison.OrdinalIgnoreCase))
                        return (string)entry.Id;
                }
                catch { /* entry is a folder or has no DisplayName — skip */ }
            }
            return null;
        }

        // ── Config file download ────────────────────────────────────────────────────

        public async Task<string> DownloadConfigXmlAsync(
            string projectId, string folderId, string configFileName, string accessToken)
        {
            var contents = await _dm.GetFolderContentsAsync(
                projectId, folderId,
                accessToken: accessToken).ConfigureAwait(false);

            if (contents?.Data == null) return null;

            string itemId = null;
            foreach (dynamic entry in contents.Data)
            {
                try
                {
                    string displayName = (string)entry.Attributes?.DisplayName;
                    if (string.Equals(displayName, configFileName, StringComparison.OrdinalIgnoreCase))
                    {
                        itemId = (string)entry.Id;
                        break;
                    }
                }
                catch { }
            }

            if (itemId == null) return null;

            // Get the tip version's storage URN
            var versions = await _dm.GetItemVersionsAsync(
                projectId, itemId, accessToken: accessToken).ConfigureAwait(false);
            var tipVersion = versions?.Data?.FirstOrDefault();
            if (tipVersion == null) return null;

            string storageUrn = tipVersion.Relationships?.Storage?.Data?.Id;
            if (string.IsNullOrEmpty(storageUrn)) return null;

            // Convert OSS storage URN to download URL
            // URN format: urn:adsk.objects:os.object:{bucket}/{object}
            string ossPath = storageUrn.Replace("urn:adsk.objects:os.object:", "");
            int slash = ossPath.IndexOf('/');
            if (slash < 0) return null;

            string bucket = Uri.EscapeDataString(ossPath[..slash]);
            string obj = Uri.EscapeDataString(ossPath[(slash + 1)..]);
            string downloadUrl = $"https://developer.api.autodesk.com/oss/v2/buckets/{bucket}/objects/{obj}";

            var request = new HttpRequestMessage(HttpMethod.Get, downloadUrl);
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            var response = await _http.SendAsync(request).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();
            return await response.Content.ReadAsStringAsync().ConfigureAwait(false);
        }

        // ── ACC custom file attributes ──────────────────────────────────────────────

        /// <summary>
        /// Reads all custom file attribute values for the given item.
        /// Returns a dictionary of { attributeDefinitionId → value }.
        ///
        /// ACC Files API endpoint:
        ///   GET https://developer.api.autodesk.com/construction/files/v1/projects/{projectId}/items/{itemId}
        /// Response shape:
        ///   { "data": { "attributes": { "customAttributes": [ { "attributeDefinitionId": "...", "value": "..." } ] } } }
        ///
        /// NOTE: projectId must NOT have the "b." prefix.
        /// </summary>
        /// <summary>
        /// Fetches all custom attribute definitions for a project.
        /// Returns two lookup maps: nameToId (name → definitionId) and idToName (definitionId → name).
        /// </summary>
        public async Task<(Dictionary<string, string> nameToId, Dictionary<string, string> idToName)>
            GetAttributeDefinitionMapsAsync(string projectId, string accessToken)
        {
            string cleanProjectId = StripBPrefix(projectId);

            var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"{AccFilesBase}/projects/{cleanProjectId}/attribute-definitions");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("application/json"));

            var response = await _http.SendAsync(request).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync().ConfigureAwait(false));
            var root = doc.RootElement;

            var nameToId = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
            var idToName = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

            if (!root.TryGetProperty("results", out var results))
                return (nameToId, idToName);

            foreach (var def in results.EnumerateArray())
            {
                string id = def.TryGetProperty("id", out var idProp) ? idProp.GetString() : null;
                string name = def.TryGetProperty("name", out var nameProp) ? nameProp.GetString() : null;
                if (id != null && name != null)
                {
                    nameToId[name] = id;
                    idToName[id] = name;
                }
            }

            return (nameToId, idToName);
        }

        public async Task<Dictionary<string, string>> GetCustomAttributesAsync(
            string projectId, string itemId, Dictionary<string, string> idToName, string accessToken)
        {
            string cleanProjectId = StripBPrefix(projectId);
            string cleanItemId = Uri.EscapeDataString(itemId);

            var request = new HttpRequestMessage(
                HttpMethod.Get,
                $"{AccFilesBase}/projects/{cleanProjectId}/items/{cleanItemId}");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
            request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("application/json"));

            var response = await _http.SendAsync(request).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();

            using var doc = JsonDocument.Parse(await response.Content.ReadAsStringAsync().ConfigureAwait(false));
            var root = doc.RootElement;

            var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

            if (!root.TryGetProperty("data", out var data)) return result;
            if (!data.TryGetProperty("attributes", out var attrs)) return result;
            if (!attrs.TryGetProperty("customAttributes", out var customAttrs)) return result;

            foreach (var attr in customAttrs.EnumerateArray())
            {
                string defId = attr.TryGetProperty("attributeDefinitionId", out var idProp)
                    ? idProp.GetString() : null;
                string val = attr.TryGetProperty("value", out var valProp) && valProp.ValueKind != JsonValueKind.Null
                    ? valProp.GetString() : null;
                if (defId != null && idToName.TryGetValue(defId, out var name))
                    result[name] = val;
            }

            return result;
        }

        /// <summary>
        /// Writes custom file attribute values to the given ACC item via a single PATCH call.
        ///
        /// PATCH https://developer.api.autodesk.com/construction/files/v1/projects/{projectId}/items/{itemId}
        /// Body: { "data": { "type": "items", "id": "{itemId}", "attributes": { "customAttributes": [...] } } }
        ///
        /// NOTE: projectId must NOT have the "b." prefix.
        /// </summary>
        public async Task PatchCustomAttributesAsync(
            string projectId, string itemId,
            IEnumerable<(string definitionId, string value)> updates,
            string accessToken)
        {
            string cleanProjectId = StripBPrefix(projectId);

            var customAttrs = new List<object>();
            foreach (var (defId, value) in updates)
                customAttrs.Add(new { attributeDefinitionId = defId, value });

            var body = new
            {
                data = new
                {
                    type = "items",
                    id = itemId,
                    attributes = new { customAttributes = customAttrs }
                }
            };

            string json = JsonSerializer.Serialize(body);
            var request = new HttpRequestMessage(
                HttpMethod.Patch,
                $"{AccFilesBase}/projects/{cleanProjectId}/items/{Uri.EscapeDataString(itemId)}")
            {
                Content = new StringContent(json, Encoding.UTF8, "application/json")
            };
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);

            var response = await _http.SendAsync(request).ConfigureAwait(false);
            response.EnsureSuccessStatusCode();
        }

        // ── Helpers ─────────────────────────────────────────────────────────────────

        private static (string hubName, string projectName, string fileName) ParseDesktopConnectorPath(
            string localPath)
        {
            string[] dcRoots = { "DC", "ACCDocs" };
            var segments = localPath.Split(
                new[] { Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar },
                StringSplitOptions.RemoveEmptyEntries);

            for (int i = 0; i < segments.Length; i++)
            {
                if (!dcRoots.Any(r => string.Equals(segments[i], r, StringComparison.OrdinalIgnoreCase)))
                    continue;
                if (i + 2 >= segments.Length) return (null, null, null);

                return (segments[i + 1], segments[i + 2], Path.GetFileName(localPath));
            }

            return (null, null, null);
        }

        private static string StripBPrefix(string id) =>
            id?.StartsWith("b.", StringComparison.OrdinalIgnoreCase) == true ? id[2..] : id;

        // Exact case-insensitive match first; falls back to normalised (trimmed, collapsed whitespace) match.
        private static T FindByName<T>(IEnumerable<T> items, Func<T, string> nameSelector, string target)
            where T : class
        {
            if (items == null || target == null) return null;
            var list = items.ToList();

            // 1. Exact case-insensitive
            var hit = list.FirstOrDefault(x =>
                string.Equals(nameSelector(x), target, StringComparison.OrdinalIgnoreCase));
            if (hit != null) return hit;

            // 2. Normalised: trim + collapse internal whitespace
            string Normalise(string s) =>
                s == null ? null : System.Text.RegularExpressions.Regex.Replace(s.Trim(), @"\s+", " ");

            string normTarget = Normalise(target);
            return list.FirstOrDefault(x =>
                string.Equals(Normalise(nameSelector(x)), normTarget, StringComparison.OrdinalIgnoreCase));
        }
    }
}
