using Autodesk.SDKManager;
using Autodesk.Authentication;
using Autodesk.Authentication.Model;
using System;
using System.Threading.Tasks;

namespace AccC3DMetadata
{
    // AuthService delegates to the Autodesk.Authentication SDK's AuthenticationClient
    // so the SDK controls how the interactive browser flow is performed.
    public class AuthService
    {
        private readonly SDKManager _sdkManager;
        private readonly AuthenticationClient _authClient;

        public AuthService()
        {
            _sdkManager = SdkManagerBuilder.Create().Build();
            _authClient = new AuthenticationClient(_sdkManager);
        }

        public async Task<ThreeLeggedToken> GetThreeLeggedTokenAsync(string clientId, string codeChallenge, string redirectUri)
        {
            if (string.IsNullOrWhiteSpace(clientId)) throw new ArgumentNullException(nameof(clientId));
            try
            {
                // Let the SDK handle the interactive flow (it should open the browser/handle redirect)
                var token = await _authClient.GetThreeLeggedTokenAsync(clientId, codeChallenge, redirectUri).ConfigureAwait(false);
                return token;
            }
            catch (Exception ex)
            {
                throw new InvalidOperationException($"Authentication SDK failed: {ex.Message}", ex);
            }
        }
    }
}
