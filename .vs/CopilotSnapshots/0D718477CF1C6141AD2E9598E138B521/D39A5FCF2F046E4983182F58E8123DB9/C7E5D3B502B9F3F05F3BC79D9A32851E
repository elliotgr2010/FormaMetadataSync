using AccC3DMetadata.Config;
using AccC3DMetadata.Models;
using AccC3DMetadata.UI;
using Autodesk.AutoCAD.ApplicationServices;
using Autodesk.AutoCAD.DatabaseServices;
using Autodesk.AutoCAD.EditorInput;
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Threading.Tasks;

namespace AccC3DMetadata.Services
{
    public class SyncResult
    {
        public int MappingsApplied { get; set; }
        public int ConflictsResolved { get; set; }
        public int ConflictsCancelled { get; set; }
        public int Errors { get; set; }
    }

    public class SyncOrchestrator
    {
        private readonly Document _doc;
        private readonly Editor _ed;
        private readonly AccFileService _acc = new();

        public SyncOrchestrator(Document doc)
        {
            _doc = doc;
            _ed = doc.Editor;
        }

        public async Task<SyncResult> RunAsync(SyncConfig config, SyncDirection direction)
        {
            string token = await TokenCache.GetAccessTokenAsync().ConfigureAwait(false);
            if (token == null)
                throw new InvalidOperationException("Could not obtain an access token.");

            // Resolve ACC hub, project, and item IDs.
            // Hub and project are always derived from the Desktop Connector path when available,
            // so hubId/projectId are not required in the XML config.
            string hubId, projectId, itemId;
            string dwgPath = _doc.Database.Filename;

            if (!string.IsNullOrEmpty(config.DrawingItemId))
            {
                itemId = config.DrawingItemId;
                try
                {
                    (hubId, projectId) = await _acc
                        .ResolveHubAndProjectAsync(dwgPath, token)
                        .ConfigureAwait(false);
                }
                catch (InvalidOperationException) when (
                    !string.IsNullOrEmpty(config.HubId) && !string.IsNullOrEmpty(config.ProjectId))
                {
                    // Drawing is not in a Desktop Connector folder; fall back to config values.
                    hubId = config.HubId;
                    projectId = config.ProjectId;
                }
            }
            else
            {
                (hubId, projectId, itemId) = await _acc
                    .ResolveItemFromDrawingPathAsync(dwgPath, token)
                    .ConfigureAwait(false);
            }

            // Attribute definitions endpoint is folder-scoped — resolve the item's parent folder first
            string folderId = await _acc.GetItemParentFolderIdAsync(projectId, itemId, token)
                .ConfigureAwait(false);
            if (folderId == null)
                throw new InvalidOperationException(
                    $"Could not resolve parent folder for item '{itemId}'. Cannot fetch attribute definitions.");

            // Fetch attribute definitions (name ↔ id maps) and then current attribute values
            var (nameToId, idToName) = await _acc.GetAttributeDefinitionMapsAsync(projectId, folderId, token)
                .ConfigureAwait(false);
            var accValues = await _acc.GetCustomAttributesAsync(projectId, itemId, idToName, token)
                .ConfigureAwait(false);

            var result = new SyncResult { MappingsApplied = config.Mappings.Count };
            var accUpdates = new List<(string id, string val)>();
            var promptConflicts = new List<SyncConflict>();

            using var tr = _doc.Database.TransactionManager.StartTransaction();
            try
            {
                var db = _doc.Database;

                foreach (var map in config.Mappings)
                {
                    try
                    {
                        bool shouldRead = direction != SyncDirection.Write
                            && map.Direction != SyncDirection.Write;
                        bool shouldWrite = direction != SyncDirection.Read
                            && map.Direction != SyncDirection.Read;

                        string accVal = accValues.GetValueOrDefault(map.AccAttributeName);
                        string dwgVal = ReadDwgValue(tr, db, map);

                        if (shouldRead && shouldWrite
                            && accVal != dwgVal
                            && map.ConflictStrategy == ConflictStrategy.Prompt)
                        {
                            promptConflicts.Add(new SyncConflict
                            {
                                Mapping = map,
                                AccValue = accVal,
                                DwgValue = dwgVal,
                                Resolution = ConflictStrategy.AccWins
                            });
                            continue;
                        }

                        ApplyResolution(tr, db, map, accVal, dwgVal,
                            map.ConflictStrategy, shouldRead, shouldWrite, accUpdates, nameToId);
                    }
                    catch (Exception ex)
                    {
                        result.Errors++;
                        _ed.WriteMessage($"\n  Error on mapping '{map.AccAttributeName}': {ex.Message}");
                    }
                }

                // Show conflict resolution dialog on the AutoCAD UI thread
                if (promptConflicts.Any())
                {
                    // Commands run with AutoCAD's SynchronizationContext; modal window is safe to call directly.
                    var dlg = new ConflictResolutionDialog(promptConflicts);
                    bool accepted = Application.ShowModalWindow(dlg) == true;

                    if (accepted)
                    {
                        foreach (var conflict in promptConflicts)
                        {
                            ApplyResolution(tr, db, conflict.Mapping,
                                conflict.AccValue, conflict.DwgValue,
                                conflict.Resolution, true, true, accUpdates, nameToId);
                        }
                        result.ConflictsResolved = promptConflicts.Count;
                    }
                    else
                    {
                        result.ConflictsCancelled = promptConflicts.Count;
                    }
                }

                tr.Commit();
            }
            catch
            {
                tr.Abort();
                throw;
            }

            // Push ACC updates as a single PATCH call
            if (accUpdates.Any())
                await _acc.PatchCustomAttributesAsync(projectId, itemId, accUpdates, token)
                    .ConfigureAwait(false);

            return result;
        }

        // ── Config loading ──────────────────────────────────────────────────────────

        public async Task<SyncConfig> LoadConfigAsync()
        {
            string dwgPath = _doc.Database.Filename;
            string dwgDir = Path.GetDirectoryName(dwgPath) ?? string.Empty;

            // Look for accsync.xml first (no DWG name prefix required)
            string genericConfig = Path.Combine(dwgDir, "accsync.xml");
            if (File.Exists(genericConfig))
                return SyncConfigParser.Parse(await File.ReadAllTextAsync(genericConfig).ConfigureAwait(false));

            // Fall back to the DWG-prefixed name for backward compatibility
            string configName = Path.GetFileNameWithoutExtension(dwgPath) + ".accsync.xml";
            string localConfig = Path.Combine(dwgDir, configName);

            if (File.Exists(localConfig))
                return SyncConfigParser.Parse(await File.ReadAllTextAsync(localConfig).ConfigureAwait(false));

            // Fall back to downloading from ACC
            _ed.WriteMessage($"\nNo config file found locally (tried 'accsync.xml' and '{configName}'). Attempting download from ACC...");
            string token = await TokenCache.GetAccessTokenAsync().ConfigureAwait(false);
            if (token == null)
                throw new InvalidOperationException("Could not obtain access token for config download.");

            var (_, projectId, itemId) = await _acc
                .ResolveItemFromDrawingPathAsync(dwgPath, token)
                .ConfigureAwait(false);

            // Use the same folder as the DWG item
            // We need the folder ID of the DWG item — get it from the item's parent relationship
            // For simplicity, we search all top folders for the config file
            string xml = null;
            var sdk = new AccFileService();
            // GetItemAsync to find the parent folder
            // NOTE: A more robust implementation would resolve the folder ID from the DWG item's parent link
            // For now, throw a helpful error directing the user to place the config locally
            if (xml == null)
                throw new FileNotFoundException(
                    $"Config file not found in the drawing's local folder.\n" +
                    $"Expected locations: {genericConfig}\n  or: {localConfig}\n" +
                    "Create this file and ensure it is synced by Desktop Connector.");

            return SyncConfigParser.Parse(xml);
        }

        // ── Private helpers ─────────────────────────────────────────────────────────

        private string ReadDwgValue(Transaction tr, Database db, SyncMapping map)
        {
            if (map.Target == MappingTarget.BlockAttribute)
            {
                return DwgBlockService
                    .ReadBlockAttributeValues(tr, db, map.BlockName, map.BlockAttributeTag)
                    .FirstOrDefault().value;
            }

            foreach (DBObject entity in DwgPropertySetService.GetEntitiesForMapping(tr, db, map))
            {
                string val = DwgPropertySetService.ReadPropertyValue(tr, entity, map.PropertySetName, map.PropertyName);
                if (val != null) return val;
            }
            return null;
        }

        private void WriteDwgValue(Transaction tr, Database db, SyncMapping map, string value)
        {
            if (map.Target == MappingTarget.BlockAttribute)
            {
                DwgBlockService.WriteBlockAttributeValues(tr, db, map.BlockName, map.BlockAttributeTag, value);
                return;
            }

            foreach (DBObject entity in DwgPropertySetService.GetEntitiesForMapping(tr, db, map))
            {
                DwgPropertySetService.EnsurePropertySetAttached(tr, entity, db, map.PropertySetName);
                DwgPropertySetService.WritePropertyValue(tr, entity, map.PropertySetName, map.PropertyName, value);
            }
        }

        private void ApplyResolution(
            Transaction tr, Database db, SyncMapping map,
            string accVal, string dwgVal, ConflictStrategy strategy,
            bool shouldRead, bool shouldWrite,
            List<(string id, string val)> accUpdates,
            Dictionary<string, string> nameToId)
        {
            if (!shouldRead && !shouldWrite) return;

            if (shouldRead && !shouldWrite)
            {
                if (accVal != null) WriteDwgValue(tr, db, map, accVal);
                return;
            }

            if (!shouldRead && shouldWrite)
            {
                QueueAccUpdate(accUpdates, nameToId, map.AccAttributeName, dwgVal);
                return;
            }

            // ReadWrite — values already equal means nothing to do
            if (accVal == dwgVal) return;

            switch (strategy)
            {
                case ConflictStrategy.AccWins:
                    if (accVal != null) WriteDwgValue(tr, db, map, accVal);
                    break;
                case ConflictStrategy.DwgWins:
                    QueueAccUpdate(accUpdates, nameToId, map.AccAttributeName, dwgVal);
                    break;
                case ConflictStrategy.Skip:
                    break;
            }
        }

        private static void QueueAccUpdate(
            List<(string id, string val)> accUpdates,
            Dictionary<string, string> nameToId,
            string attributeName, string value)
        {
            if (value == null || attributeName == null) return;
            if (!nameToId.TryGetValue(attributeName, out var defId)) return;
            accUpdates.Add((defId, value));
        }
    }
}
